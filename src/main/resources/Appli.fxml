<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>



<BorderPane prefHeight="800.0" prefWidth="1280.0" styleClass="racine" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="frontend.ui.controllers.GraphController">

   <!-- ===== En-tête ===== -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="10" styleClass="entete-haut">
         <padding>
            <Insets bottom="12" left="20" right="20" top="12"/>
         </padding>

         <ImageView fitWidth="32" fitHeight="32" preserveRatio="true">
            <image>
               <Image url="@/images/logo.png"/>
            </image>
         </ImageView>

         <Label text="CARPE" styleClass="entete-titre"/>

         <Region HBox.hgrow="ALWAYS"/>

         <Button fx:id="menuButton" styleClass="entete-menu" text="≡"/>
         <ToggleButton fx:id="toggleAPCM" styleClass="entete-menu" text="ACPM"/>
         <Button fx:id="checkConnexite" styleClass="entete-menu" text="Connexité"/>
         <Button fx:id="creditsButton" styleClass="entete-menu" text="Crédits"/>
      </HBox>
   </top>

   <!-- ===== Barre latérale ===== -->
   <left>
      <VBox prefWidth="260.0" spacing="22" styleClass="barre-laterale">
         <padding>
            <Insets bottom="20" left="18" right="18" top="20" />
         </padding>

         <VBox spacing="10" styleClass="bloc-lateral">
            <Label styleClass="bloc-titre" text="Itinéraires" />
            <Label fx:id="optionsVideLabel" styleClass="bloc-note" text="Calculez un trajet pour voir les options." wrapText="true" />
            <VBox fx:id="optionsBox" managed="false" spacing="8" visible="false" />
         </VBox>

         <VBox spacing="10" styleClass="bloc-lateral" VBox.vgrow="ALWAYS">
            <Label styleClass="bloc-titre" text="Historique" />
            <VBox fx:id="historiqueBox" spacing="8" />
            <Label fx:id="historiqueVideLabel" styleClass="bloc-note" text="Vos trajets récents apparaîtront ici." wrapText="true" />
         </VBox>
      </VBox>
   </left>

   <!-- ===== Zone centrale : recherche + carte ===== -->
   <center>
      <VBox>

         <VBox spacing="10" styleClass="zone-recherche">
            <padding>
               <Insets bottom="14" left="24" right="24" top="18" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="14">

               <VBox alignment="CENTER" minWidth="14" spacing="2">
                  <Label styleClass="repere-depart" text="○" />
                  <Region maxHeight="22" minHeight="22" styleClass="repere-trait" />
                  <Label styleClass="repere-arrivee" text="📍" />
               </VBox>

               <VBox spacing="8" HBox.hgrow="ALWAYS">
                  <TextField fx:id="departField" promptText="Choisir un point de départ..." styleClass="champ-recherche" />
                  <TextField fx:id="arriveField" promptText="Choisir une destination..." styleClass="champ-recherche" />
               </VBox>

               <Button fx:id="echangerButton" styleClass="bouton-echanger" text="⇅" />
               <Button fx:id="rechercherButton" styleClass="bouton-principal" text="Calculer" />

               <VBox alignment="CENTER" spacing="2">
                  <Label styleClass="champ-mini-label" text="Ligne" />
                  <ChoiceBox fx:id="lineChoice" maxWidth="170" prefWidth="170" />
               </VBox>
            </HBox>

            <Label fx:id="erreurLabel" managed="false" styleClass="erreur" visible="false" wrapText="true" />

            <HBox fx:id="resultatBox" alignment="CENTER_LEFT" managed="false" spacing="14" styleClass="carte-resultat" visible="false">
               <Label fx:id="resultatTempsLabel" styleClass="resultat-temps" />
               <Label fx:id="resultatDetailLabel" styleClass="resultat-detail" wrapText="true" HBox.hgrow="ALWAYS" />
            </HBox>
         </VBox>

         <Pane fx:id="viewportPane" styleClass="viewport" VBox.vgrow="ALWAYS">
            <Pane fx:id="graphPane" />
         </Pane>

      </VBox>
   </center>

   <right>
      <VBox fx:id="creditsPane" spacing="12" visible="false" managed="false" prefWidth="320" >
         <padding><Insets top="20" right="16" left="16" bottom="20"/></padding>
         <HBox alignment="CENTER_RIGHT">
            <Button text="✕" onAction="#showCredits"  />
         </HBox>
         <Label  text="Crédits" />
         <Label text="CARPE - SolutionDelivery" wrapText="true"/>
         <Label text="Développé par: Mathis BUCLON, Nathan CORNUAU, Ayuna CHAMPAIN, Karel BOU FERRAA, Noham BOULANOUAR" wrapText="true"/>
         <Label text="Version: 1.0" />
         <Label wrapText="true" text="Données : Portail Open Data IDFM. Format GTFS. Datée de octobre 2024. Les fichiers ont été traités et nettoyés pour garder seulement les informations liées au métro" />
         <Region VBox.vgrow="ALWAYS" />
      </VBox>
   </right>
</BorderPane>
